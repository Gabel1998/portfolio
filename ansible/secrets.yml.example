---
# Copy to secrets.yml (gitignored) and fill in, then run:
#   ansible-playbook playbook.yml -e @secrets.yml
#
# Better: encrypt it —  ansible-vault encrypt secrets.yml
# and run with  --ask-vault-pass  (or a vault password file).
#
# Create the DigitalOcean Space + Spaces access keys first:
#   DO console → Spaces → Create, then API → Spaces Keys → Generate.
# Set backup_s3_region / backup_s3_bucket in group_vars/all.yml to match.

restic_password: "a-long-random-passphrase-keep-this-safe-you-need-it-to-restore"
backup_s3_access_key: "DO_SPACES_ACCESS_KEY"
backup_s3_secret_key: "DO_SPACES_SECRET_KEY"
